# Supabase (lib/supabase/server.ts, client.ts, admin.ts 에서 사용)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (회사 메일 자동 발송용, Phase 5에서 사용)
RESEND_API_KEY=
CONTACT_RECEIVER_EMAIL=

# SEO (Phase 6) — 실 도메인 연결 전까지는 비워두면 placeholder URL을 사용한다.
# lib/seo/site.ts. Phase 7 배포 시 실제 도메인으로 교체.
NEXT_PUBLIC_SITE_URL=

# GA4 측정 ID(G-XXXXXXXXXX). 비워두면 GoogleAnalytics 컴포넌트가 아무 것도
# 렌더링하지 않는다(components/analytics/GoogleAnalytics.tsx).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# 카카오맵 JavaScript 키(오시는 길 지도, components/sections/KakaoMap.tsx).
# 비워두면 안내 메시지만 표시된다. 발급 방법은 답변 본문 참고.
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=
